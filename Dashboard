        <div class="bg-slate-50 rounded-lg p-4 text-center border border-slate-100"><div class="text-xs text-slate-500 uppercase tracking-wider">PAS</div><div id="detailPAS" class="text-2xl font-bold mt-1 text-emerald-600"></div></div>
