// ===================== RENDER: MANAGE CONSULTANTS =====================
function renderConsultantsTable() {
  var tbody = document.getElementById('consultantsTableBody');
  tbody.innerHTML = consultants.map(function(c) {
    return '<tr class="hover:bg-slate-50 transition">' +
      '<td class="px-6 py-4"><div class="flex items-center gap-3"><div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold text-xs">' + c.initials + '</div><div class="font-medium text-slate-800">' + c.name + '</div></div></td>' +
      '<td class="px-4 py-4 text-center"><span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">' + c.level + '</span></td>' +
      '<td class="px-4 py-4 text-center text-slate-600">' + c.tenure + 'y</td>' +
      '<td class="px-4 py-4 text-center text-slate-600">' + c.trainingHours + '</td>' +
      '<td class="px-4 py-4 text-center text-slate-600">' + c.mockCalls + '</td>' +
      '<td class="px-4 py-4 text-center">' + (c.certified ? '<span class="text-emerald-600 text-xs font-medium">&#10003; Yes</span>' : '<span class="text-slate-400 text-xs">No</span>') + '</td>' +
      '<td class="px-4 py-4 text-center"><button onclick="editConsultant(' + c.id + ')" class="text-indigo-600 hover:text-indigo-800 text-xs font-medium mr-3">Edit</button><button onclick="deleteConsultant(' + c.id + ')" class="text-red-600 hover:text-red-800 text-xs font-medium">Delete</button></td>' +
      '</tr>';
  }).join('');
}

function openAddConsultantModal() {
  document.getElementById('modalTitle').textContent = 'Add Consultant';
  document.getElementById('editConsultantId').value = '';
  document.getElementById('consultantName').value = '';
  document.getElementById('consultantLevel').value = 'Trainee';
  document.getElementById('consultantTenure').value = '';
  document.getElementById('consultantHours').value = '0';
  document.getElementById('consultantMocks').value = '0';
  document.getElementById('consultantCertified').checked = false;
  document.getElementById('consultantModal').classList.remove('hidden');
  document.getElementById('consultantModal').classList.add('flex');
}

function editConsultant(id) {
  var c = consultants.find(function(x) { return x.id === id; });
  if (!c) return;
  document.getElementById('modalTitle').textContent = 'Edit Consultant';
  document.getElementById('editConsultantId').value = c.id;
  document.getElementById('consultantName').value = c.name;
  document.getElementById('consultantLevel').value = c.level;
  document.getElementById('consultantTenure').value = c.tenure;
  document.getElementById('consultantHours').value = c.trainingHours;
  document.getElementById('consultantMocks').value = c.mockCalls;
  document.getElementById('consultantCertified').checked = c.certified;
  document.getElementById('consultantModal').classList.remove('hidden');
  document.getElementById('consultantModal').classList.add('flex');
}

function saveConsultant() {
  var id = document.getElementById('editConsultantId').value;
  var name = document.getElementById('consultantName').value.trim();
  var level = document.getElementById('consultantLevel').value;
  var tenure = parseFloat(document.getElementById('consultantTenure').value) || 0;
  var hours = parseInt(document.getElementById('consultantHours').value) || 0;
  var mocks = parseInt(document.getElementById('consultantMocks').value) || 0;
  var certified = document.getElementById('consultantCertified').checked;

  if (!name) { alert('Please enter a name'); return; }

  if (id) {
    var c = consultants.find(function(x) { return x.id == id; });
    if (c) {
      c.name = name;
      c.initials = getInitials(name);
      c.level = level;
      c.tenure = tenure;
      c.trainingHours = hours;
      c.mockCalls = mocks;
      c.certified = certified;
    }
  } else {
    consultants.push({
      id: nextConsultantId++,
      name: name,
      initials: getInitials(name),
      level: level,
      tenure: tenure,
      certified: certified,
      trainingHours: hours,
      mockCalls: mocks
    });
  }

  saveAllData();
  closeConsultantModal();
  renderConsultantsTable();
  populateDropdowns();
  renderHeatmap();
  renderCertPipeline();
}

function deleteConsultant(id) {
  if (!confirm('Delete this consultant and all their QA data?')) return;
  consultants = consultants.filter(function(c) { return c.id !== id; });
  delete qaData[id];
  saveAllData();
  renderConsultantsTable();
  populateDropdowns();
  renderHeatmap();
}

function closeConsultantModal() {
  document.getElementById('consultantModal').classList.add('hidden');
  document.getElementById('consultantModal').classList.remove('flex');
}

// ===================== RENDER: CERTIFICATION =====================
function renderCertPipeline() {
  var pipeline = consultants.filter(function(c) { return !c.certified || c.level === 'Certified Associate'; }).map(function(c) {
    var score60 = get60DayAverage(c.id);
    var target = c.level === 'Trainee' ? 'Certified Associate' : 'Certified Specialist';
    var hoursNeeded = c.level === 'Trainee' ? 20 : 40;
    var mocksNeeded = c.level === 'Trainee' ? 3 : 5;
    var readiness = Math.round((score60 / 100) * 40 + (c.trainingHours / hoursNeeded) * 30 + (c.mockCalls / mocksNeeded) * 30);
    readiness = Math.min(100, readiness);
    return { name: c.name, current: c.level, target: target, hours: c.trainingHours, mock: c.mockCalls, score60: score60, readiness: readiness };
  });

  document.getElementById('certPipeline').innerHTML = pipeline.map(function(p) {
    var readyColor = p.readiness >= 75 ? 'bg-emerald-500' : p.readiness >= 50 ? 'bg-amber-400' : 'bg-red-500';
    var canCertify = p.readiness >= 75 && p.hours >= (p.target === 'Certified Associate' ? 20 : 40) && p.mock >= (p.target === 'Certified Associate' ? 3 : 5);
    return '<tr class="hover:bg-slate-50 transition">' +
      '<td class="px-6 py-4 font-medium text-slate-800">' + p.name + '</td>' +
      '<td class="px-4 py-4 text-center"><span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">' + p.current + '</span></td>' +
      '<td class="px-4 py-4 text-center">' + p.hours + '/' + (p.target === 'Certified Associate' ? '20' : '40') + ' hrs</td>' +
      '<td class="px-4 py-4 text-center">' + p.mock + '/' + (p.target === 'Certified Associate' ? '3' : '5') + ' mocks</td>' +
      '<td class="px-4 py-4 text-center font-bold ' + getScoreTextColor(p.score60) + '">' + p.score60 + '</td>' +
      '<td class="px-4 py-4"><div class="flex items-center gap-2"><div class="w-20 h-2 bg-slate-100 rounded-full overflow-hidden"><div class="h-full ' + readyColor + ' rounded-full score-bar" style="width:' + p.readiness + '%"></div></div><span class="text-xs font-medium">' + p.readiness + '%</span></div></td>' +
      '<td class="px-4 py-4 text-center">' + (canCertify ? '<button class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs px-3 py-1.5 rounded-lg font-medium transition">Certify Now</button>' : '<button class="bg-slate-100 text-slate-400 text-xs px-3 py-1.5 rounded-lg cursor-not-allowed">Not Ready</button>') + '</td></tr>';
  }).join('');

  document.getElementById('certInTraining').textContent = consultants.filter(function(c) { return !c.certified; }).length;
  document.getElementById('certPending').textContent = pipeline.filter(function(p) { return p.readiness >= 50 && p.readiness < 75; }).length;
  document.getElementById('certRecert').textContent = consultants.filter(function(c) { return c.certified && get60DayAverage(c.id) < 75; }).length;
}

function get60DayAverage(consultantId) {
  var scores = [];
  var today = new Date();
  for (var i = 0; i < 60; i++) {
    var d = new Date(today);
    d.setDate(d.getDate() - i);
    var dateStr = d.toISOString().split('T')[0];
    var daily = getDailyAverage(consultantId, dateStr);
    if (daily > 0) scores.push(daily);
  }
  return scores.length > 0 ? Math.round(scores.reduce(function(a,b){return a+b;}, 0) / scores.length) : 0;
}

// ===================== RENDER: ALERTS =====================
function renderRemediation() {
  var today = document.getElementById('qaDateSelect') ? document.getElementById('qaDateSelect').value : new Date().toISOString().split('T')[0];
  var tasks = [];

  consultants.forEach(function(c) {
    var avg = getDailyAverage(c.id, today);
    if (avg > 0) {
      if (avg < 55) {
        tasks.push({ consultant: c.name, type: 'RED', task: 'Immediate coaching - Composite ' + avg, assigned: 'Manager', due: 'ASAP' });
      } else if (avg < 70) {
        tasks.push({ consultant: c.name, type: 'AMBER', task: 'Review weak points - Score ' + avg, assigned: 'Senior Trainer', due: '48 hrs' });
      }
    }
  });

  document.getElementById('remediationTasks').innerHTML = tasks.length > 0 ? tasks.map(function(t) {
    var color = t.type === 'RED' ? 'border-l-4 border-l-red-500' : 'border-l-4 border-l-amber-500';
    return '<div class="px-6 py-4 ' + color + ' hover:bg-slate-50 transition">' +
      '<div class="flex items-start justify-between"><div><div class="font-medium text-slate-800">' + t.task + '</div>' +
      '<div class="text-xs text-slate-500 mt-1">Consultant: ' + t.consultant + ' - Assigned: ' + t.assigned + ' - Due: ' + t.due + '</div></div>' +
      '<span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded">' + t.type + '</span></div></div>';
  }).join('') : '<div class="px-6 py-8 text-center text-slate-400">No alerts today. Team is performing well!</div>';
}

// ===================== DETAIL MODAL =====================
function openDetailModal(id) {
  var c = consultants.find(function(x) { return x.id === id; });
  if (!c) return;
  var today = document.getElementById('qaDateSelect') ? document.getElementById('qaDateSelect').value : new Date().toISOString().split('T')[0];
  var avgChs = 0, avgPas = 0, avgCes = 0, avgComp = 0, count = 0;

  customers.forEach(function(cust) {
    if (hasAnyData(c.id, today, cust.id)) {
      avgChs += getDomainScore(c.id, today, cust.id, 'chs');
      avgPas += getDomainScore(c.id, today, cust.id, 'pas');
      avgCes += getDomainScore(c.id, today, cust.id, 'ces');
      avgComp += getCompositeScore(c.id, today, cust.id);
      count++;
    }
  });

  var chs = count > 0 ? Math.round(avgChs / count) : 0;
  var pas = count > 0 ? Math.round(avgPas / count) : 0;
  var ces = count > 0 ? Math.round(avgCes / count) : 0;
  var comp = count > 0 ? Math.round(avgComp / count) : 0;

  document.getElementById('detailAvatar').textContent = c.initials;
  document.getElementById('detailName').textContent = c.name;
  document.getElementById('detailRole').textContent = c.level + ' - ' + c.tenure + ' years - 60-day avg: ' + get60DayAverage(c.id);
  document.getElementById('detailScore').textContent = comp > 0 ? comp : '-';
  document.getElementById('detailScore').className = 'text-2xl font-bold mt-1 ' + (comp > 0 ? getScoreTextColor(comp) : 'text-slate-400');
  document.getElementById('detailCHS').textContent = chs > 0 ? chs : '-';
  document.getElementById('detailPAS').textContent = pas > 0 ? pas : '-';
  document.getElementById('detailCES').textContent = ces > 0 ? ces : '-';

  // 30-day trend
  var chart = document.getElementById('detailChart');
  var trend = [];
  for (var i = 29; i >= 0; i--) {
    var d = new Date();
    d.setDate(d.getDate() - i);
    var ds = d.toISOString().split('T')[0];
    var avg = getDailyAverage(c.id, ds);
    if (avg > 0) trend.push({ date: ds.slice(5), score: avg });
  }

  if (trend.length > 0) {
    var maxScore = Math.max.apply(null, trend.map(function(t) { return t.score; }).concat([1]));
    chart.innerHTML = trend.map(function(t) {
      return '<div class="flex flex-col items-center gap-1 flex-1"><div class="w-full bg-indigo-500 rounded-t transition-all duration-500 hover:bg-indigo-600 relative group cursor-pointer" style="height: ' + (t.score/maxScore*100) + '%">' +
        '<div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition whitespace-nowrap z-10">' + t.score + '</div></div>' +
        '<span class="text-[10px] text-slate-400">' + t.date + '</span></div>';
    }).join('');
  } else {
    chart.innerHTML = '<div class="flex items-center justify-center w-full h-full text-slate-400 text-sm">No historical data yet</div>';
  }

  // Aggregate weak points across all customers today
  var allWeak = [];
  customers.forEach(function(cust) {
    if (hasAnyData(c.id, today, cust.id)) {
      var weak = getWeakPoints(c.id, today, cust.id);
      allWeak = allWeak.concat(weak);
    }
  });

  // Deduplicate weak points
  var uniqueWeak = [];
  var seen = {};
  allWeak.forEach(function(w) {
    var key = w.domain + '|' + w.item;
    if (!seen[key]) { seen[key] = true; uniqueWeak.push(w); }
  });

  document.getElementById('detailWeakPoints').innerHTML = uniqueWeak.length > 0 ? uniqueWeak.slice(0, 8).map(function(w) {
    return '<div class="flex items-start gap-2 p-2 bg-red-50 rounded-lg border border-red-100"><span class="text-xs font-bold text-red-500 w-8">' + w.domain + '</span><span class="text-xs text-slate-700">' + w.item + '</span></div>';
  }).join('') : '<div class="text-sm text-slate-400 italic">No weak points - excellent!</div>';

  var allStrong = [];
  customers.forEach(function(cust) {
    if (hasAnyData(c.id, today, cust.id)) {
      var strong = getStrengths(c.id, today, cust.id);
      allStrong = allStrong.concat(strong);
    }
  });

  var uniqueStrong = [];
  var seenStrong = {};
  allStrong.forEach(function(s) {
    var key = s.domain + '|' + s.item;
    if (!seenStrong[key]) { seenStrong[key] = true; uniqueStrong.push(s); }
  });

  document.getElementById('detailStrengths').innerHTML = uniqueStrong.length > 0 ? uniqueStrong.slice(0, 8).map(function(s) {
    return '<div class="flex items-start gap-2 p-2 bg-emerald-50 rounded-lg border border-emerald-100"><span class="text-xs font-bold text-emerald-500 w-8">' + s.domain + '</span><span class="text-xs text-slate-700">' + s.item + '</span></div>';
  }).join('') : '<div class="text-sm text-slate-400 italic">No strengths marked yet</div>';

  document.getElementById('detailModal').classList.remove('hidden');
  document.getElementById('detailModal').classList.add('flex');
}

function closeDetailModal() {
  document.getElementById('detailModal').classList.add('hidden');
  document.getElementById('detailModal').classList.remove('flex');
}

