<script>
// ===================== CHECKLIST DEFINITIONS =====================
const checklistItems = {
  chs: [
    { id: 'chs_1', label: 'Maintains chest register / authority voice throughout call' },
    { id: 'chs_2', label: 'Pace controlled at 130-150 WPM (not rushed)' },
    { id: 'chs_3', label: 'Uses silence discipline: 4+ seconds after diagnostic questions' },
    { id: 'chs_4', label: 'Handles interruptions with Stop-Freeze-Volume Drop protocol' },
    { id: 'chs_5', label: 'Zero upspeak incidents (statements sound like statements)' },
    { id: 'chs_6', label: 'Sets clear next step / payment ask / close before ending' },
    { id: 'chs_7', label: 'Active listening: paraphrases client concerns accurately' },
    { id: 'chs_8', label: 'Controls call direction without being pushy' }
  ],
  pas: [
    { id: 'pas_1', label: 'Intake form 100% complete before call (ECA status, spouse, job duties)' },
    { id: 'pas_2', label: 'NOC code validated with duty mapping present' },
    { id: 'pas_3', label: 'Evidence checklist uploaded and verified in CRM' },
    { id: 'pas_4', label: 'ECA ordered / proof of funds verified / NIW letters requested' },
    { id: 'pas_5', label: 'All SLA deadlines met (tasks within target days)' },
    { id: 'pas_6', label: 'Correct product recommendation based on client profile' },
    { id: 'pas_7', label: 'Fee disclosure done at correct stage (not rushed, not delayed)' },
    { id: 'pas_8', label: 'Documentation accuracy: no errors in client data entry' }
  ],
  ces: [
    { id: 'ces_1', label: 'Proposal sent within 24 hours of discovery call' },
    { id: 'ces_2', label: 'Follow-up calls completed on scheduled dates' },
    { id: 'ces_3', label: 'Objections handled with structured rebuttal (not defensive)' },
    { id: 'ces_4', label: 'Payment collected or payment plan confirmed' },
    { id: 'ces_5', label: 'No unnecessary reprice events after discovery' },
    { id: 'ces_6', label: 'Conversion from qualified lead to paid client' },
    { id: 'ces_7', label: 'Time from intake to first payment within target' },
    { id: 'ces_8', label: 'Upsell / cross-sell attempted where appropriate' }
  ]
};

const certLevels = ['Trainee', 'Certified Associate', 'Certified Specialist', 'Master Trainer'];

// ===================== DEFAULT DATA =====================
var defaultConsultants = [
  { id: 1, name: "Ahmed Hassan", initials: "AH", level: "Certified Specialist", tenure: 3.5, certified: true, trainingHours: 45, mockCalls: 6 },
  { id: 2, name: "Fatima Al-Rashid", initials: "FA", level: "Certified Specialist", tenure: 2.8, certified: true, trainingHours: 42, mockCalls: 5 },
  { id: 3, name: "Raj Patel", initials: "RP", level: "Certified Associate", tenure: 1.2, certified: true, trainingHours: 24, mockCalls: 3 },
  { id: 4, name: "Sarah Kim", initials: "SK", level: "Trainee", tenure: 0.4, certified: false, trainingHours: 12, mockCalls: 1 },
  { id: 5, name: "Omar Khalil", initials: "OK", level: "Master Trainer", tenure: 5.1, certified: true, trainingHours: 60, mockCalls: 8 }
];

var defaultCustomers = [
  { id: 'c1', name: 'Kumar Family', product: 'Canada PR' },
  { id: 'c2', name: 'Al-Farsi Corp', product: 'Australia NIW' },
  { id: 'c3', name: 'Zhang Household', product: 'Visit Visa UK' },
  { id: 'c4', name: 'Hassan Brothers', product: 'Canada PNP' },
  { id: 'c5', name: 'Patel Group', product: 'EB2 NIW USA' }
];

// ===================== STATE =====================
var consultants = [];
var customers = [];
var qaData = {}; // qaData[consultantId][date][customerId][itemId] = true/false
var nextConsultantId = 100;
var nextCustomerId = 100;

// ===================== STORAGE =====================
function loadAllData() {
  var savedConsultants = localStorage.getItem('hof_consultants');
  var savedCustomers = localStorage.getItem('hof_customers');
  var savedQA = localStorage.getItem('hof_qa_data');
  var savedNextId = localStorage.getItem('hof_next_id');
  var savedNextCustId = localStorage.getItem('hof_next_cust_id');

  if (savedConsultants) {
    consultants = JSON.parse(savedConsultants);
  } else {
    consultants = JSON.parse(JSON.stringify(defaultConsultants));
  }

  if (savedCustomers) {
    customers = JSON.parse(savedCustomers);
  } else {
    customers = JSON.parse(JSON.stringify(defaultCustomers));
  }

  if (savedQA) {
    qaData = JSON.parse(savedQA);
  }

  if (savedNextId) nextConsultantId = parseInt(savedNextId);
  if (savedNextCustId) nextCustomerId = parseInt(savedNextCustId);
}

function saveAllData() {
  localStorage.setItem('hof_consultants', JSON.stringify(consultants));
  localStorage.setItem('hof_customers', JSON.stringify(customers));
  localStorage.setItem('hof_qa_data', JSON.stringify(qaData));
  localStorage.setItem('hof_next_id', nextConsultantId);
  localStorage.setItem('hof_next_cust_id', nextCustomerId);
  showToast('All data saved!');
}

function resetAllData() {
  if (confirm('WARNING: This will delete ALL consultants, customers, and QA data. Are you sure?')) {
    localStorage.removeItem('hof_consultants');
    localStorage.removeItem('hof_customers');
    localStorage.removeItem('hof_qa_data');
    localStorage.removeItem('hof_next_id');
    localStorage.removeItem('hof_next_cust_id');
    location.reload();
  }
}

function showToast(msg) {
  var toast = document.createElement('div');
  toast.className = 'fixed bottom-4 right-4 bg-emerald-600 text-white px-4 py-2 rounded-lg shadow-lg text-sm font-medium z-50 fade-in';
  toast.textContent = msg;
  document.body.appendChild(toast);
  setTimeout(function() { toast.remove(); }, 3000);
}

function getInitials(name) {
  return name.split(' ').map(function(n) { return n[0]; }).join('').toUpperCase().slice(0, 2);
}

// ===================== SCORING =====================
function getCheckedCount(consultantId, date, customerId, domain) {
  var items = checklistItems[domain];
  var checked = 0;
  items.forEach(function(item) {
    if (qaData[consultantId] && qaData[consultantId][date] && qaData[consultantId][date][customerId] && qaData[consultantId][date][customerId][item.id]) {
      checked++;
    }
  });
  return checked;
}

function getDomainScore(consultantId, date, customerId, domain) {
  var total = checklistItems[domain].length;
  var checked = getCheckedCount(consultantId, date, customerId, domain);
  return Math.round((checked / total) * 100);
}

function getCompositeScore(consultantId, date, customerId) {
  var chs = getDomainScore(consultantId, date, customerId, 'chs');
  var pas = getDomainScore(consultantId, date, customerId, 'pas');
  var ces = getDomainScore(consultantId, date, customerId, 'ces');
  return Math.round(chs * 0.35 + pas * 0.35 + ces * 0.30);
}

// Get average across all customers for a date
function getDailyAverage(consultantId, date) {
  var scores = [];
  customers.forEach(function(cust) {
    var s = getCompositeScore(consultantId, date, cust.id);
    if (s > 0 || hasAnyData(consultantId, date, cust.id)) scores.push(s);
  });
  return scores.length > 0 ? Math.round(scores.reduce(function(a,b){return a+b;}, 0) / scores.length) : 0;
}

function hasAnyData(consultantId, date, customerId) {
  if (!qaData[consultantId] || !qaData[consultantId][date] || !qaData[consultantId][date][customerId]) return false;
  return Object.keys(qaData[consultantId][date][customerId]).length > 0;
}

function getStatus(score) {
  if (score >= 85) return 'Good';
  if (score >= 70) return 'Amber';
  if (score >= 55) return 'Amber';
  return 'Red';
}

function getWeakPoints(consultantId, date, customerId) {
  var weak = [];
  ['chs','pas','ces'].forEach(function(domain) {
    checklistItems[domain].forEach(function(item) {
      if (!qaData[consultantId] || !qaData[consultantId][date] || !qaData[consultantId][date][customerId] || !qaData[consultantId][date][customerId][item.id]) {
        weak.push({ domain: domain.toUpperCase(), item: item.label });
      }
    });
  });
  return weak;
}

function getStrengths(consultantId, date, customerId) {
  var strong = [];
  ['chs','pas','ces'].forEach(function(domain) {
    checklistItems[domain].forEach(function(item) {
      if (qaData[consultantId] && qaData[consultantId][date] && qaData[consultantId][date][customerId] && qaData[consultantId][date][customerId][item.id]) {
        strong.push({ domain: domain.toUpperCase(), item: item.label });
      }
    });
  });
  return strong;
}

// ===================== STYLING HELPERS =====================
function getScoreColor(score) {
  if (score >= 85) return 'bg-emerald-500';
  if (score >= 70) return 'bg-amber-400';
  if (score >= 55) return 'bg-orange-400';
  return 'bg-red-500';
}

function getScoreTextColor(score) {
  if (score >= 85) return 'text-emerald-600';
  if (score >= 70) return 'text-amber-600';
  if (score >= 55) return 'text-orange-600';
  return 'text-red-600';
}

function getStatusBadge(status) {
  var colors = { 'Good': 'bg-emerald-100 text-emerald-700', 'Amber': 'bg-amber-100 text-amber-700', 'Red': 'bg-red-100 text-red-700' };
  return '<span class="px-2.5 py-1 rounded-full text-xs font-semibold ' + colors[status] + '">' + status + '</span>';
}

// ===================== RENDER: OVERVIEW =====================
function renderHeatmap() {
  var tbody = document.getElementById('heatmapBody');
  var today = document.getElementById('qaDateSelect') ? document.getElementById('qaDateSelect').value : new Date().toISOString().split('T')[0];

  tbody.innerHTML = consultants.map(function(c) {
    var avgChs = 0, avgPas = 0, avgCes = 0, avgComp = 0, count = 0;
    customers.forEach(function(cust) {
      if (hasAnyData(c.id, today, cust.id)) {
        avgChs += getDomainScore(c.id, today, cust.id, 'chs');
        avgPas += getDomainScore(c.id, today, cust.id, 'pas');
        avgCes += getDomainScore(c.id, today, cust.id, 'ces');
        avgComp += getCompositeScore(c.id, today, cust.id);
        count++;
      }
    });
    var chs = count > 0 ? Math.round(avgChs / count) : 0;
    var pas = count > 0 ? Math.round(avgPas / count) : 0;
    var ces = count > 0 ? Math.round(avgCes / count) : 0;
    var comp = count > 0 ? Math.round(avgComp / count) : 0;
    var status = comp > 0 ? getStatus(comp) : 'N/A';

    return '<tr class="hover:bg-slate-50 cursor-pointer transition" onclick="openDetailModal(' + c.id + ')">' +
      '<td class="px-6 py-4"><div class="flex items-center gap-3"><div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold text-xs">' + c.initials + '</div>' +
      '<div><div class="font-medium text-slate-800">' + c.name + '</div><div class="text-xs text-slate-400">' + c.tenure + 'y tenure</div></div></div></td>' +
      '<td class="px-4 py-4 text-center text-slate-600">' + c.tenure + 'y</td>' +
      '<td class="px-4 py-4 text-center"><span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">' + c.level + '</span></td>' +
      '<td class="px-4 py-4 text-center"><div class="flex items-center justify-center gap-2"><div class="w-16 h-2 bg-slate-100 rounded-full overflow-hidden"><div class="h-full ' + getScoreColor(chs) + ' rounded-full score-bar" style="width:' + chs + '%"></div></div><span class="text-xs font-medium w-6">' + (chs > 0 ? chs : '-') + '</span></div></td>' +
      '<td class="px-4 py-4 text-center"><div class="flex items-center justify-center gap-2"><div class="w-16 h-2 bg-slate-100 rounded-full overflow-hidden"><div class="h-full ' + getScoreColor(pas) + ' rounded-full score-bar" style="width:' + pas + '%"></div></div><span class="text-xs font-medium w-6">' + (pas > 0 ? pas : '-') + '</span></div></td>' +
      '<td class="px-4 py-4 text-center"><div class="flex items-center justify-center gap-2"><div class="w-16 h-2 bg-slate-100 rounded-full overflow-hidden"><div class="h-full ' + getScoreColor(ces) + ' rounded-full score-bar" style="width:' + ces + '%"></div></div><span class="text-xs font-medium w-6">' + (ces > 0 ? ces : '-') + '</span></div></td>' +
      '<td class="px-4 py-4 text-center font-bold ' + (comp > 0 ? getScoreTextColor(comp) : 'text-slate-400') + '">' + (comp > 0 ? comp : '-') + '</td>' +
      '<td class="px-4 py-4 text-center">' + (status !== 'N/A' ? getStatusBadge(status) : '<span class="text-xs text-slate-400">No data</span>') + '</td>' +
      '<td class="px-4 py-4 text-center"><button class="text-indigo-600 hover:text-indigo-800 text-xs font-medium px-2 py-1 rounded hover:bg-indigo-50 transition" onclick="event.stopPropagation();openDetailModal(' + c.id + ')">View</button></td>' +
      '</tr>';
  }).join('');

  updateKPIs();
  renderTeamWeakPoints();
  updateAlertCounts();
}

function renderTeamWeakPoints() {
  var today = document.getElementById('qaDateSelect') ? document.getElementById('qaDateSelect').value : new Date().toISOString().split('T')[0];
  var counts = {};

  consultants.forEach(function(c) {
    customers.forEach(function(cust) {
      if (hasAnyData(c.id, today, cust.id)) {
        var weak = getWeakPoints(c.id, today, cust.id);
        weak.forEach(function(w) {
          var key = w.domain + ': ' + w.item;
          counts[key] = (counts[key] || 0) + 1;
        });
      }
    });
  });

  var sorted = Object.entries(counts).sort(function(a, b) { return b[1] - a[1]; }).slice(0, 5);

  document.getElementById('teamWeakPoints').innerHTML = sorted.length > 0 ? sorted.map(function(item) {
    var pct = Math.round((item[1] / consultants.length) * 100);
    var color = pct >= 50 ? 'bg-red-500' : pct >= 30 ? 'bg-orange-400' : 'bg-amber-400';
    return '<div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100">' +
      '<div class="flex items-center gap-3"><span class="text-xs font-bold text-slate-500 w-12">' + item[0].split(':')[0] + '</span>' +
      '<span class="text-sm text-slate-700">' + item[0].split(': ')[1] + '</span></div>' +
      '<div class="flex items-center gap-3"><div class="w-24 h-2 bg-slate-200 rounded-full overflow-hidden"><div class="h-full ' + color + ' rounded-full score-bar" style="width:' + pct + '%"></div></div>' +
      '<span class="text-xs font-medium w-8 text-right">' + item[1] + '</span></div></div>';
  }).join('') : '<div class="text-sm text-slate-400 italic p-4">No QA data for today yet. Go to Daily QA Checklist to start marking.</div>';
}

function updateKPIs() {
  var today = document.getElementById('qaDateSelect') ? document.getElementById('qaDateSelect').value : new Date().toISOString().split('T')[0];
  var totalScore = 0, scoredCount = 0, atRisk = 0, certifiedCount = 0;

  consultants.forEach(function(c) {
    var daily = getDailyAverage(c.id, today);
    if (daily > 0) {
      totalScore += daily;
      scoredCount++;
      if (daily < 70) atRisk++;
    }
    if (c.certified) certifiedCount++;
  });

  var avg = scoredCount > 0 ? Math.round(totalScore / scoredCount) : 0;

  document.getElementById('kpiTotal').textContent = consultants.length;
  document.getElementById('kpiTotalIcon').textContent = consultants.length;
  document.getElementById('kpiAvgScore').textContent = avg > 0 ? avg : '--';
  document.getElementById('kpiAtRisk').textContent = atRisk;
  document.getElementById('kpiCertRate').textContent = consultants.length > 0 ? Math.round((certifiedCount / consultants.length) * 100) + '%' : '0%';
  document.getElementById('kpiCertDetail').textContent = certifiedCount + ' of ' + consultants.length + ' certified';
}

function updateAlertCounts() {
  var today = document.getElementById('qaDateSelect') ? document.getElementById('qaDateSelect').value : new Date().toISOString().split('T')[0];
  var red = 0, amber = 0;

  consultants.forEach(function(c) {
    var avg = getDailyAverage(c.id, today);
    if (avg > 0) {
      if (avg < 55) red++;
      else if (avg < 70) amber++;
    }
  });

  document.getElementById('alertRedCount').textContent = red;
  document.getElementById('alertAmberCount').textContent = amber;
  document.getElementById('alertBadge').textContent = red + amber;
}

// ===================== RENDER: QA CHECKLIST =====================
function renderQAChecklist() {
  var container = document.getElementById('qaChecklistContainer');
  var date = document.getElementById('qaDateSelect').value;
  var selectedConsultant = document.getElementById('qaConsultantSelect').value;
  var selectedCustomer = document.getElementById('qaCustomerSelect').value;

  var filteredConsultants = selectedConsultant === 'all' ? consultants : consultants.filter(function(c) { return c.id == selectedConsultant; });
  var filteredCustomers = selectedCustomer === 'all' ? customers : customers.filter(function(c) { return c.id == selectedCustomer; });

  var html = '';

  filteredConsultants.forEach(function(c) {
    filteredCustomers.forEach(function(cust) {
      var chsScore = getDomainScore(c.id, date, cust.id, 'chs');
      var pasScore = getDomainScore(c.id, date, cust.id, 'pas');
      var cesScore = getDomainScore(c.id, date, cust.id, 'ces');
      var comp = getCompositeScore(c.id, date, cust.id);
      var hasData = hasAnyData(c.id, date, cust.id);

      var renderDomain = function(domain, title, colorClass) {
        var items = checklistItems[domain];
        return '<div class="mb-4"><h4 class="font-semibold text-sm mb-2 flex items-center gap-2"><span class="w-2 h-2 rounded-full ' + colorClass + '"></span>' + title + ' (' + (hasData ? getDomainScore(c.id, date, cust.id, domain) : 0) + '%)</h4>' +
          '<div class="grid grid-cols-1 gap-1">' +
          items.map(function(item) {
            var checked = qaData[c.id] && qaData[c.id][date] && qaData[c.id][date][cust.id] && qaData[c.id][date][cust.id][item.id] ? 'checked' : '';
            return '<label class="flex items-start gap-3 p-2 rounded-lg cursor-pointer hover:bg-slate-50 transition">' +
              '<input type="checkbox" ' + checked + ' onchange="toggleChecklistItem(' + c.id + ', \'' + date + '\', \'' + cust.id + '\', \'' + item.id + '\', this.checked)" class="mt-0.5 w-4 h-4 rounded border-slate-300 text-indigo-600">' +
              '<span class="text-sm text-slate-700">' + item.label + '</span>' +
              '</label>';
          }).join('') +
          '</div></div>';
      };

      html += '<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">' +
        '<div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50">' +
        '<div class="flex items-center gap-4">' +
        '<div class="flex items-center gap-3"><div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold">' + c.initials + '</div>' +
        '<div><div class="font-bold text-slate-800">' + c.name + '</div><div class="text-xs text-slate-500">' + c.level + '</div></div></div>' +
        '<div class="h-8 w-px bg-slate-200"></div>' +
        '<div><div class="text-xs text-slate-400">Customer</div><div class="font-medium text-sm text-slate-700">' + cust.name + '</div><div class="text-xs text-slate-400">' + cust.product + '</div></div>' +
        '</div>' +
        '<div class="flex items-center gap-4">' +
        '<div class="text-center"><div class="text-xs text-slate-400">CHS</div><div class="font-bold ' + getScoreTextColor(chsScore) + '">' + (hasData ? chsScore : '-') + '</div></div>' +
        '<div class="text-center"><div class="text-xs text-slate-400">PAS</div><div class="font-bold ' + getScoreTextColor(pasScore) + '">' + (hasData ? pasScore : '-') + '</div></div>' +
        '<div class="text-center"><div class="text-xs text-slate-400">CES</div><div class="font-bold ' + getScoreTextColor(cesScore) + '">' + (hasData ? cesScore : '-') + '</div></div>' +
        '<div class="text-center px-3 py-1 bg-slate-100 rounded-lg"><div class="text-xs text-slate-400">Composite</div><div class="font-bold text-lg ' + (hasData ? getScoreTextColor(comp) : 'text-slate-400') + '">' + (hasData ? comp : '-') + '</div></div>' +
        '</div></div>' +
        '<div class="p-6">' +
        renderDomain('chs', 'Call Handling (CHS)', 'bg-blue-500') +
        renderDomain('pas', 'Process Adherence (PAS)', 'bg-emerald-500') +
        renderDomain('ces', 'Closing Effectiveness (CES)', 'bg-amber-500') +
        '</div></div>';
    });
  });

  container.innerHTML = html || '<div class="text-center py-12 text-slate-400">No consultants or customers found. Add them in Manage Consultants.</div>';
}

function toggleChecklistItem(consultantId, date, customerId, itemId, checked) {
  if (!qaData[consultantId]) qaData[consultantId] = {};
  if (!qaData[consultantId][date]) qaData[consultantId][date] = {};
  if (!qaData[consultantId][date][customerId]) qaData[consultantId][date][customerId] = {};
  qaData[consultantId][date][customerId][itemId] = checked;
  saveAllData();
  renderQAChecklist();
  renderHeatmap();
}

