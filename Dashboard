<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HOF Migration - Consultant QA Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
body { font-family: 'Inter', sans-serif; }
.score-bar { transition: width 0.6s ease; }
.fade-in { animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: #f1f5f9; }
::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
.modal-overlay { background: rgba(0,0,0,0.5); }
</style>
<base target="_blank">
</head>
<body class="min-h-screen bg-slate-50 text-slate-800">

<nav class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between sticky top-0 z-50">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-indigo-600 rounded-lg flex items-center justify-center text-white font-bold text-lg">H</div>
    <div>
      <h1 class="font-bold text-lg leading-tight">HOF Migration</h1>
      <p class="text-xs text-slate-500">Consultant QA Dashboard</p>
    </div>
  </div>
  <div class="flex items-center gap-3">
    <div class="flex items-center gap-2 text-sm">
      <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
      <span class="text-slate-600">Live</span>
    </div>
    <div class="bg-slate-100 rounded-full px-4 py-1.5 text-sm font-medium" id="currentDate"></div>
    <button onclick="saveAllData()" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      Save
    </button>
    <button onclick="exportReport()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">Export</button>
  </div>
</nav>

<div class="flex">
  <aside class="w-64 bg-white border-r border-slate-200 min-h-screen p-4 hidden lg:block">
    <div class="space-y-1">
      <button onclick="switchView('overview')" id="nav-overview" class="w-full text-left px-4 py-2.5 rounded-lg text-sm font-medium bg-indigo-50 text-indigo-700 flex items-center gap-3 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
        Executive Overview
      </button>
      <button onclick="switchView('qa-checklist')" id="nav-qa-checklist" class="w-full text-left px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-50 flex items-center gap-3 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        Daily QA Checklist
      </button>
      <button onclick="switchView('consultants')" id="nav-consultants" class="w-full text-left px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-50 flex items-center gap-3 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        Manage Consultants
      </button>
      <button onclick="switchView('certification')" id="nav-certification" class="w-full text-left px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-50 flex items-center gap-3 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Certification Center
      </button>
      <button onclick="switchView('alerts')" id="nav-alerts" class="w-full text-left px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-50 flex items-center gap-3 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        Alerts & Tasks
        <span id="alertBadge" class="ml-auto bg-red-500 text-white text-xs px-2 py-0.5 rounded-full">0</span>
      </button>
    </div>

    <div class="mt-8 pt-6 border-t border-slate-200">
      <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Scoring Weights</h3>
      <div class="space-y-3">
        <div><div class="flex justify-between text-xs mb-1"><span>Call Handling (CHS)</span><span class="font-medium">35%</span></div><div class="h-1.5 bg-slate-100 rounded-full overflow-hidden"><div class="h-full bg-blue-500 rounded-full score-bar" style="width:35%"></div></div></div>
        <div><div class="flex justify-between text-xs mb-1"><span>Process Adherence (PAS)</span><span class="font-medium">35%</span></div><div class="h-1.5 bg-slate-100 rounded-full overflow-hidden"><div class="h-full bg-emerald-500 rounded-full score-bar" style="width:35%"></div></div></div>
        <div><div class="flex justify-between text-xs mb-1"><span>Closing Effectiveness (CES)</span><span class="font-medium">30%</span></div><div class="h-1.5 bg-slate-100 rounded-full overflow-hidden"><div class="h-full bg-amber-500 rounded-full score-bar" style="width:30%"></div></div></div>
      </div>
    </div>
  </aside>

  <main class="flex-1 p-6 overflow-auto">

    <!-- OVERVIEW VIEW -->
    <div id="view-overview" class="space-y-6 fade-in">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm"><div class="flex items-center justify-between mb-3"><span class="text-sm text-slate-500 font-medium">Active Consultants</span><div class="w-8 h-8 bg-indigo-50 rounded-lg flex items-center justify-center"><span class="text-indigo-600 font-bold text-sm" id="kpiTotalIcon">0</span></div></div><div class="text-3xl font-bold text-slate-800" id="kpiTotal">0</div><div class="text-xs text-emerald-600 mt-1 font-medium">Total team size</div></div>
        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm"><div class="flex items-center justify-between mb-3"><span class="text-sm text-slate-500 font-medium">Certification Rate</span><div class="w-8 h-8 bg-emerald-50 rounded-lg flex items-center justify-center"><span class="text-emerald-600 font-bold text-sm">%</span></div></div><div class="text-3xl font-bold text-slate-800" id="kpiCertRate">0%</div><div class="text-xs text-emerald-600 mt-1 font-medium" id="kpiCertDetail">0 certified</div></div>
        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm"><div class="flex items-center justify-between mb-3"><span class="text-sm text-slate-500 font-medium">Avg Score (Today)</span><div class="w-8 h-8 bg-amber-50 rounded-lg flex items-center justify-center"><span class="text-amber-600 font-bold text-sm">Avg</span></div></div><div class="text-3xl font-bold text-slate-800" id="kpiAvgScore">--</div><div class="text-xs text-amber-600 mt-1 font-medium">Based on QA checklists</div></div>
        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm"><div class="flex items-center justify-between mb-3"><span class="text-sm text-slate-500 font-medium">At Risk Today</span><div class="w-8 h-8 bg-red-50 rounded-lg flex items-center justify-center"><span class="text-red-600 font-bold text-sm">!</span></div></div><div class="text-3xl font-bold text-slate-800" id="kpiAtRisk">0</div><div class="text-xs text-red-600 mt-1 font-medium">Need intervention</div></div>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
          <h2 class="font-bold text-slate-800">Performance Heatmap</h2>
          <div class="flex items-center gap-2 text-xs"><span class="w-3 h-3 rounded bg-emerald-500"></span><span class="text-slate-500">85-100</span><span class="w-3 h-3 rounded bg-amber-400"></span><span class="text-slate-500">70-84</span><span class="w-3 h-3 rounded bg-orange-400"></span><span class="text-slate-500">55-69</span><span class="w-3 h-3 rounded bg-red-500"></span><span class="text-slate-500">&lt;55</span></div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 text-slate-500 text-xs uppercase">
              <tr><th class="px-6 py-3 text-left font-semibold">Consultant</th><th class="px-4 py-3 text-center font-semibold">Tenure</th><th class="px-4 py-3 text-center font-semibold">Level</th><th class="px-4 py-3 text-center font-semibold">CHS</th><th class="px-4 py-3 text-center font-semibold">PAS</th><th class="px-4 py-3 text-center font-semibold">CES</th><th class="px-4 py-3 text-center font-semibold">Composite</th><th class="px-4 py-3 text-center font-semibold">Status</th><th class="px-4 py-3 text-center font-semibold">Action</th></tr>
            </thead>
            <tbody id="heatmapBody" class="divide-y divide-slate-100"></tbody>
          </table>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 shadow-sm">
        <div class="px-6 py-4 border-b border-slate-100"><h2 class="font-bold text-slate-800">Top Weak Points Across Team</h2><p class="text-sm text-slate-500 mt-1">Most frequently unchecked items = what to train on</p></div>
        <div class="p-6"><div id="teamWeakPoints" class="space-y-3"></div></div>
      </div>
    </div>

    <!-- QA CHECKLIST VIEW -->
    <div id="view-qa-checklist" class="space-y-6 hidden fade-in">
      <div class="flex items-center justify-between flex-wrap gap-3">
        <div>
          <h2 class="text-xl font-bold text-slate-800">Daily QA Checklist</h2>
          <p class="text-sm text-slate-500 mt-1">Check what the consultant did WELL today. Unchecked = weak point.</p>
        </div>
        <div class="flex gap-2 flex-wrap">
          <input type="date" id="qaDateSelect" class="border border-slate-200 rounded-lg px-4 py-2 text-sm" onchange="loadDateData()">
          <select id="qaConsultantSelect" class="border border-slate-200 rounded-lg px-4 py-2 text-sm" onchange="loadConsultantQA()"><option value="all">All Consultants</option></select>
          <select id="qaCustomerSelect" class="border border-slate-200 rounded-lg px-4 py-2 text-sm" onchange="loadConsultantQA()"><option value="all">All Customers</option></select>
        </div>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <div class="text-sm text-amber-800"><span class="font-semibold">How it works:</span> Check = consultant is STRONG in this area. Leave unchecked = WEAK POINT. Score = % of checked items per domain. Select a date and customer to mark per call.</div>
      </div>

      <div id="qaChecklistContainer" class="space-y-6"></div>
    </div>

    <!-- MANAGE CONSULTANTS VIEW -->
    <div id="view-consultants" class="space-y-6 hidden fade-in">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-xl font-bold text-slate-800">Manage Consultants</h2>
          <p class="text-sm text-slate-500 mt-1">Add, edit, or remove consultants from the team.</p>
        </div>
        <button onclick="openAddConsultantModal()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add Consultant
        </button>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-slate-500 text-xs uppercase">
            <tr>
              <th class="px-6 py-3 text-left font-semibold">Consultant</th>
              <th class="px-4 py-3 text-center font-semibold">Level</th>
              <th class="px-4 py-3 text-center font-semibold">Tenure</th>
              <th class="px-4 py-3 text-center font-semibold">Training Hours</th>
              <th class="px-4 py-3 text-center font-semibold">Mock Calls</th>
              <th class="px-4 py-3 text-center font-semibold">Certified</th>
              <th class="px-4 py-3 text-center font-semibold">Actions</th>
            </tr>
          </thead>
          <tbody id="consultantsTableBody" class="divide-y divide-slate-100"></tbody>
        </table>
      </div>
    </div>

    <!-- CERTIFICATION VIEW -->
    <div id="view-certification" class="space-y-6 hidden fade-in">
      <div class="flex items-center justify-between"><h2 class="text-xl font-bold text-slate-800">Certification Center</h2></div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm"><div class="text-sm text-slate-500 mb-1">In Training</div><div class="text-3xl font-bold text-slate-800" id="certInTraining">0</div></div>
        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm"><div class="text-sm text-slate-500 mb-1">Pending Assessment</div><div class="text-3xl font-bold text-slate-800" id="certPending">0</div></div>
        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm"><div class="text-sm text-slate-500 mb-1">Recertification Due</div><div class="text-3xl font-bold text-slate-800" id="certRecert">0</div></div>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100"><h3 class="font-bold text-slate-800">Certification Pipeline</h3></div>
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-slate-500 text-xs uppercase">
            <tr><th class="px-6 py-3 text-left">Consultant</th><th class="px-4 py-3 text-center">Current Level</th><th class="px-4 py-3 text-center">Training Hours</th><th class="px-4 py-3 text-center">Mock Calls</th><th class="px-4 py-3 text-center">60-Day Score</th><th class="px-4 py-3 text-center">Readiness</th><th class="px-4 py-3 text-center">Action</th></tr>
          </thead>
          <tbody id="certPipeline" class="divide-y divide-slate-100"></tbody>
        </table>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <h3 class="font-bold text-slate-800 mb-4">Certification Criteria</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-3">
            <div class="flex items-start gap-3 p-3 bg-slate-50 rounded-lg border border-slate-100"><div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600 font-bold text-sm shrink-0">CA</div><div><div class="font-semibold text-sm">Certified Associate</div><div class="text-xs text-slate-500 mt-1">20 hrs training - 3 mock calls - Score >=75 - 30 discovery calls</div></div></div>
            <div class="flex items-start gap-3 p-3 bg-slate-50 rounded-lg border border-slate-100"><div class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center text-purple-600 font-bold text-sm shrink-0">CS</div><div><div class="font-semibold text-sm">Certified Specialist</div><div class="text-xs text-slate-500 mt-1">40 hrs training - 5 supervised cases - NIW/Canada/Aus exam - Score >=80</div></div></div>
            <div class="flex items-start gap-3 p-3 bg-slate-50 rounded-lg border border-slate-100"><div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center text-amber-600 font-bold text-sm shrink-0">MT</div><div><div class="font-semibold text-sm">Master Trainer</div><div class="text-xs text-slate-500 mt-1">12 months as CS - Certified 3+ associates - Leadership approval</div></div></div>
          </div>
          <div class="border border-slate-200 rounded-lg p-4 bg-slate-50">
            <h4 class="font-semibold text-sm mb-3">Recertification Rules</h4>
            <ul class="text-xs text-slate-600 space-y-2">
              <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold">&#10003;</span> Every 12 months mandatory</li>
              <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold">&#10003;</span> Triggered if score drops below 70 for 30 days</li>
              <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold">&#10003;</span> 30-day remediation plan before revocation</li>
              <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold">&#10003;</span> Appeal window: 72 hours for human review</li>
              <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold">&#10003;</span> New hires: 60-day ramp (scores weighted 0.7)</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- ALERTS VIEW -->
    <div id="view-alerts" class="space-y-6 hidden fade-in">
      <div class="flex items-center justify-between"><h2 class="text-xl font-bold text-slate-800">Alerts & Remediation Tasks</h2></div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-red-50 border border-red-200 rounded-xl p-5"><div class="flex items-center gap-2 mb-2"><span class="w-2 h-2 rounded-full bg-red-500"></span><span class="text-sm font-semibold text-red-800">RED Alerts</span></div><div class="text-3xl font-bold text-red-700" id="alertRedCount">0</div><div class="text-xs text-red-600 mt-1">Immediate action required</div></div>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-5"><div class="flex items-center gap-2 mb-2"><span class="w-2 h-2 rounded-full bg-amber-500"></span><span class="text-sm font-semibold text-amber-800">AMBER Alerts</span></div><div class="text-3xl font-bold text-amber-700" id="alertAmberCount">0</div><div class="text-xs text-amber-600 mt-1">Coach within 48 hours</div></div>
        <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-5"><div class="flex items-center gap-2 mb-2"><span class="w-2 h-2 rounded-full bg-emerald-500"></span><span class="text-sm font-semibold text-emerald-800">Resolved</span></div><div class="text-3xl font-bold text-emerald-700">0</div><div class="text-xs text-emerald-600 mt-1">This month</div></div>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100"><h3 class="font-bold text-slate-800">Active Remediation Tasks</h3></div>
        <div id="remediationTasks" class="divide-y divide-slate-100"></div>
      </div>
    </div>

  </main>
</div>

<!-- Add/Edit Consultant Modal -->
<div id="consultantModal" class="fixed inset-0 modal-overlay hidden items-center justify-center z-50 p-4">
  <div class="bg-white rounded-2xl max-w-lg w-full shadow-2xl fade-in">
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
      <h2 class="font-bold text-xl text-slate-800" id="modalTitle">Add Consultant</h2>
      <button onclick="closeConsultantModal()" class="text-slate-400 hover:text-slate-600 text-2xl w-8 h-8 flex items-center justify-center rounded-lg hover:bg-slate-100 transition">&times;</button>
    </div>
    <div class="p-6 space-y-4">
      <input type="hidden" id="editConsultantId">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
        <input type="text" id="consultantName" class="w-full border border-slate-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="e.g. Ahmed Hassan">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Certification Level</label>
          <select id="consultantLevel" class="w-full border border-slate-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="Trainee">Trainee</option>
            <option value="Certified Associate">Certified Associate</option>
            <option value="Certified Specialist">Certified Specialist</option>
            <option value="Master Trainer">Master Trainer</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Tenure (years)</label>
          <input type="number" id="consultantTenure" step="0.1" min="0" class="w-full border border-slate-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="e.g. 2.5">
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Training Hours</label>
          <input type="number" id="consultantHours" min="0" class="w-full border border-slate-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="e.g. 24">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Mock Calls Completed</label>
