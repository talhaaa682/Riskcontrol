function switchView(view) {
  ['overview','qa-checklist','consultants','certification','alerts'].forEach(function(v) {
    document.getElementById('view-' + v).classList.add('hidden');
    document.getElementById('nav-' + v).classList.remove('bg-indigo-50', 'text-indigo-700');
    document.getElementById('nav-' + v).classList.add('text-slate-600');
  });
  document.getElementById('view-' + view).classList.remove('hidden');
  document.getElementById('nav-' + view).classList.add('bg-indigo-50', 'text-indigo-700');
  document.getElementById('nav-' + view).classList.remove('text-slate-600');

  if (view === 'qa-checklist') renderQAChecklist();
  if (view === 'consultants') renderConsultantsTable();
  if (view === 'certification') renderCertPipeline();
  if (view === 'alerts') renderRemediation();
}

function populateDropdowns() {
  var cSelect = document.getElementById('qaConsultantSelect');
  var custSelect = document.getElementById('qaCustomerSelect');

  // Save current selection
  var cVal = cSelect.value;
  var custVal = custSelect.value;

  // Clear and repopulate consultants
  cSelect.innerHTML = '<option value="all">All Consultants</option>';
  consultants.forEach(function(c) {
    var opt = document.createElement('option');
    opt.value = c.id;
    opt.textContent = c.name;
    cSelect.appendChild(opt);
  });
  cSelect.value = cVal;

  // Clear and repopulate customers
  custSelect.innerHTML = '<option value="all">All Customers</option>';
  customers.forEach(function(c) {
    var opt = document.createElement('option');
    opt.value = c.id;
    opt.textContent = c.name + ' (' + c.product + ')';
    custSelect.appendChild(opt);
  });
  custSelect.value = custVal;
}

function exportReport() {
  var today = document.getElementById('qaDateSelect') ? document.getElementById('qaDateSelect').value : new Date().toISOString().split('T')[0];
  var csv = 'Consultant,Level,Tenure,Date,Customer,Product,CHS,PAS,CES,Composite,Status\n';
  consultants.forEach(function(c) {
    customers.forEach(function(cust) {
      if (hasAnyData(c.id, today, cust.id)) {
        var chs = getDomainScore(c.id, today, cust.id, 'chs');
        var pas = getDomainScore(c.id, today, cust.id, 'pas');
        var ces = getDomainScore(c.id, today, cust.id, 'ces');
        var comp = getCompositeScore(c.id, today, cust.id);
        csv += c.name + ',' + c.level + ',' + c.tenure + ',' + today + ',' + cust.name + ',' + cust.product + ',' + chs + ',' + pas + ',' + ces + ',' + comp + ',' + getStatus(comp) + '\n';
      }
    });
  });
  var blob = new Blob([csv], { type: 'text/csv' });
  var url = window.URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = 'hof_qa_report_' + today + '.csv';
  a.click();
}

